datasource db {
  provider = "postgresql"
  // 🟢 A URL foi removida por exigência do Prisma v7
}

generator client {
  provider = "prisma-client-js"
}

// ... (mantenha suas models Lead, User e Log como estão)

model Lead {
  id          String   @id @default(cuid())
  name        String
  priority    Int?  @default(1)
  email       String
  phone       String
  source      String
  status      String @default("New")
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  logs        Log[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([email])
  @@index([phone])
}

model User {
  id                 String   @id @default(cuid())
  name               String
  email              String   @unique
  role               String   @default("Sales")
  isActive           Boolean  @default(true)
  lastAssignedLeadAt DateTime @default(now()) 
  leads              Lead[]
  createdAt          DateTime @default(now())
}

model Log {
  id          String   @id @default(cuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id])
  message     String
  createdAt   DateTime @default(now())
}